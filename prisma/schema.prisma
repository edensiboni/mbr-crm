generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_DIRECT")
}

model Customer {
  id          String   @id @default(cuid())
  name        String
  email       String?  @unique
  phone       String
  address     String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  cases       Case[]

  @@map("customers")
}

model Case {
  id              String      @id @default(cuid())
  caseNumber      String      @unique
  customerId      String
  customer        Customer    @relation(fields: [customerId], references: [id], onDelete: Cascade)

  title           String
  status          String      @default("intake")
  priority        String      @default("normal")

  laptopModel     String
  serialNumber    String?
  purchaseYear    Int?

  issueType       String
  issueDescription String
  physicalCondition String     @default("good")

  diagnosticNotes  String?
  repairNotes      String?
  partsUsed        String?

  estimatedCost    Float?
  finalCost        Float?
  depositPaid      Float?

  estimatedCompletion DateTime?
  completedAt     DateTime?

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  communications  Communication[]
  notes           Note[]
  images          CaseImage[]

  @@map("cases")
}

model CaseImage {
  id        String   @id @default(cuid())
  caseId    String
  case      Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  type      String   // "intake" | "completion"
  filename  String
  url       String
  createdAt DateTime @default(now())

  @@map("case_images")
}

model Communication {
  id        String   @id @default(cuid())
  caseId    String
  case      Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  type      String
  direction String   @default("outbound")
  content   String
  createdAt DateTime @default(now())

  @@map("communications")
}

model Note {
  id        String   @id @default(cuid())
  caseId    String
  case      Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  content   String
  createdAt DateTime @default(now())

  @@map("notes")
}

model Listing {
  id            String         @id @default(cuid())
  title         String
  model         String
  year          Int
  price         Float
  condition     String         @default("good")
  ram           String?
  storage       String?
  processor     String?
  color         String?
  batteryHealth Int?
  description   String?
  status        String         @default("available")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  images        ListingImage[]

  @@map("listings")
}

model ListingImage {
  id        String   @id @default(cuid())
  listingId String
  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
  url       String
  filename  String
  createdAt DateTime @default(now())

  @@map("listing_images")
}
