# Database — local dev uses SQLite, production uses PostgreSQL (Neon)
DATABASE_PROVIDER="sqlite"
DATABASE_URL="file:./dev.db"

# For production (Vercel + Neon), set these instead:
# DATABASE_PROVIDER="postgresql"
# DATABASE_URL="postgresql://user:pass@host/dbname?sslmode=require"

# AI Agent — get from console.anthropic.com (optional, pay-per-use)
ANTHROPIC_API_KEY="your-anthropic-api-key"

# Image Storage — get from cloudinary.com (free, no credit card)
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"
